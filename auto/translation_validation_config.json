{
  "$schema": "Translation Validation Configuration Schema v1",
  "comment": "Configuration for zh translation validation",
  
  "source_base": ".",
  "translation_base": "zh",
  
  "path_patterns": [
    {
      "name": "root_claude",
      "pattern": "CLAUDE.md",
      "description": "Root CLAUDE instruction file"
    },
    {
      "name": "root_readme",
      "pattern": "README.md",
      "description": "Root README"
    },
    {
      "name": "root_upgrading",
      "pattern": "UPGRADING.md",
      "description": "Root upgrade guide"
    },
    {
      "name": "design_docs",
      "pattern": "design/**/*.md",
      "description": "Design documents"
    },
    {
      "name": "design_yaml",
      "pattern": "design/**/*.yaml",
      "description": "Design YAML data"
    },
    {
      "name": "design_yml",
      "pattern": "design/**/*.yml",
      "description": "Design YML data"
    },
    {
      "name": "source_code",
      "pattern": "src/**/*.md",
      "description": "Source documentation"
    },
    {
      "name": "github_templates",
      "pattern": ".github/**/*",
      "description": "GitHub templates and workflows"
    },
    {
      "name": "agents",
      "pattern": ".claude/agents/**/*.md",
      "description": "Agent definitions"
    },
    {
      "name": "skills",
      "pattern": ".claude/skills/**/*.md",
      "description": "Skill files"
    },
    {
      "name": "claude_docs",
      "pattern": ".claude/docs/**/*.md",
      "description": "Claude documentation"
    },
    {
      "name": "claude_docs_yaml",
      "pattern": ".claude/docs/**/*.yaml",
      "description": "Claude YAML documentation"
    },
    {
      "name": "claude_docs_yml",
      "pattern": ".claude/docs/**/*.yml",
      "description": "Claude YML documentation"
    },
    {
      "name": "rules",
      "pattern": ".claude/rules/**/*.md",
      "description": "Rule files"
    },
    {
      "name": "docs",
      "pattern": "docs/**/*.md",
      "description": "General documentation"
    },
    {
      "name": "docs_yaml",
      "pattern": "docs/**/*.yaml",
      "description": "General YAML documentation"
    },
    {
      "name": "docs_yml",
      "pattern": "docs/**/*.yml",
      "description": "General YML documentation"
    },
    {
      "name": "testing_framework",
      "pattern": "CCGS Skill Testing Framework/**/*",
      "description": "Testing framework files"
    }
  ],
  
  "zh_only_whitelist": [
    "zh/GLOSSARY.md",
    "zh/docs/ARCHITECTURE.md",
    "zh/.gitkeep",
    "zh/**/.gitkeep"
  ],
  
  "frontmatter_rules": {
    "agent": {
      "protected_keys": ["name", "tools", "model", "memory", "disallowedTools", "maxTurns", "skills"],
      "translatable_keys": ["description"],
      "description": "Agent definition files"
    },
    "skill": {
      "protected_keys": ["name", "user-invocable", "allowed-tools", "agent", "model"],
      "translatable_keys": ["description", "argument-hint"],
      "description": "Skill definition files"
    },
    "rules": {
      "protected_keys": ["paths"],
      "translatable_keys": [],
      "description": "Rule files with path definitions"
    },
    "github": {
      "protected_keys": ["title", "labels", "assignees"],
      "translatable_keys": ["name", "about"],
      "description": "GitHub issue/PR templates"
    }
  },
  
  "markdown_checks": {
    "frontmatter": true,
    "slash_commands": true,
    "heading_count": true,
    "code_fences": true,
    "relative_links": true,
    "truncation_heuristics": true
  },
  
  "truncation_thresholds": {
    "heading_loss_threshold": 2,
    "line_ratio_min": 0.7,
    "description": "Thresholds for truncation detection"
  },
  
  "yaml_checks": {
    "key_stability": true,
    "protected_values": ["paths", "status", "commands"],
    "description": "YAML file validation rules"
  },
  
  "severity_levels": {
    "missing_translation": "error",
    "unexpected_zh_file": "warning",
    "frontmatter_missing": "error",
    "frontmatter_unclosed": "error",
    "frontmatter_key_mismatch": "warning",
    "protected_value_changed": "error",
    "slash_command_missing": "warning",
    "heading_count_mismatch": "warning",
    "code_fence_broken": "error",
    "broken_link": "error",
    "truncation_suspected": "error",
    "yaml_key_mismatch": "warning",
    "yaml_protected_changed": "error"
  },
  
  "output": {
    "terminal_summary": true,
    "markdown_report": "auto/reports/validation_report.md",
    "json_report": "auto/reports/validation_report.json"
  }
}
